# Solana network (localnet | devnet | mainnet-beta)
  SOLANA_CLUSTER=devnet
  SOLANA_RPC_URL=https://api.devnet.solana.com

  # Program ID (after running: anchor deploy)
  PROGRAM_ID=DAoFRGExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

  # Wallet path (default: ~/.config/solana/id.json)
  WALLET_PATH=~/.config/solana/id.json

  # Web app (Next.js)
  NEXT_PUBLIC_PROGRAM_ID=DAoFRGExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
  NEXT_PUBLIC_SOLANA_NETWORK=devnet
  NEXT_PUBLIC_RPC_ENDPOINT=https://api.devnet.solana.com
  